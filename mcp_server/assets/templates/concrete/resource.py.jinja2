{#- concrete/resource.py.jinja2 - Resource Python Class -#}
{%- extends "tier2_base_python.jinja2" -%}
{%- import "tier3_pattern_python_logging.jinja2" as p_logging -%}

{#-
TEMPLATE_METADATA:
  enforcement: GUIDELINE
  level: concrete
  artifact_type: resource
  extends: tier2_base_python.jinja2
  purpose: "Concrete template for resource classes"
  version: "1.0.0"
  introspection:
    template_id: resource
    tier: concrete
    parent: tier2_base_python
    variables:
      required:
        - name
      optional:
        - description
        - resource_type
        - methods
  agent_hints:
    phase: "green"
    purpose: "Generate MCP resource classes"
-#}

{% block module_docstring %}
"""{{ name }} module.

{{ description | default('Resource implementation.') }}

@layer: MCP (Resources)
@resource_type: {{ resource_type | default('Unspecified') }}
"""
{% endblock %}

{% block imports_section %}
# Standard library
{{ p_logging.pattern_logging_imports() }}

# Third-party

# Project modules

{% endblock %}

{% block class_structure %}
{{ p_logging.pattern_logging_get_logger() }}

class {{ name }}:
    """{{ description | default(name + ' resource.') }}"""
{% if methods %}
{% for method in methods %}

    def {{ method.name }}(self{% if method.params %}, {{ method.params }}{% endif %}){% if method.return_type %} -> {{ method.return_type }}{% endif %}:
        """{{ method.docstring | default(method.name + ' resource method.') }}"""
        {{ method.body | default('pass') | indent(8) }}
{% endfor %}
{% else %}

    def read(self):
        """Return resource content."""
        return None
{% endif %}
{% endblock %}
