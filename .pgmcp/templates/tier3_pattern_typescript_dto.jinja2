  {%- set name_type = field_decl.split(':') -%}
  {%- set f_name = name_type[0] | trim -%}
  {%- set f_type = name_type[1] | trim if name_type | length > 1 else 'string' -%}
  {{ "    " }}{{ f_name }}: {{ f_type }};
{% endfor %}
  }) {
{% for field_str in fields %}
  {%- set parts = field_str.strip().split() -%}
  {%- if parts[0] == 'readonly' -%}
    {%- set field_decl = parts[1:] | join(' ') -%}
  {%- else -%}
    {%- set field_decl = parts | join(' ') -%}
  {%- endif -%}
  {%- set name_type = field_decl.split(':') -%}
  {%- set f_name = name_type[0] | trim -%}
  {{ "    " }}this.{{ f_name }} = data.{{ f_name }};
{% endfor %}
  }
{% endblock %}
