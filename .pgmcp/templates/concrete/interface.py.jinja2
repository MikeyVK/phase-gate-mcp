{#- concrete/interface.py.jinja2 - Interface Protocol -#}
{%- extends "tier2_base_python.jinja2" -%}

{#-
TEMPLATE_METADATA:
  enforcement: GUIDELINE
  level: concrete
  artifact_type: interface
  extends: tier2_base_python.jinja2
  purpose: "Concrete template for interface protocols"
  version: "1.0.0"
  introspection:
    template_id: interface
    tier: concrete
    parent: tier2_base_python
    variables:
      required:
        - name
      optional:
        - description
        - methods
  agent_hints:
    phase: "green"
    purpose: "Generate protocol-style interfaces"
-#}

{% block module_docstring %}
"""{{ name }} module.

{{ description | default('Interface definition.') }}

@layer: Backend (Contracts)
"""
{% endblock %}

{% block imports_section %}
# Standard library
from typing import Protocol

# Third-party

# Project modules

{% endblock %}

{% block class_structure %}
class {{ name }}(Protocol):
    """{{ description | default(name + ' interface.') }}"""
{% if methods %}
{% for method in methods %}

    def {{ method.name }}(self{% if method.params %}, {{ method.params }}{% endif %}){% if method.return_type %} -> {{ method.return_type }}{% endif %}:
        """{{ method.docstring | default(method.name + ' contract.') }}"""
        ...
{% endfor %}
{% else %}

    def execute(self) -> None:
        """Execute the contract operation."""
        ...
{% endif %}
{% endblock %}
