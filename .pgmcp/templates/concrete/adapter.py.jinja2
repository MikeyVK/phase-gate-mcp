{#- concrete/adapter.py.jinja2 - Adapter Python Class -#}
{%- extends "tier2_base_python.jinja2" -%}
{%- import "tier3_pattern_python_logging.jinja2" as p_logging -%}

{#-
TEMPLATE_METADATA:
  enforcement: GUIDELINE
  level: concrete
  artifact_type: adapter
  extends: tier2_base_python.jinja2
  purpose: "Concrete template for adapter classes"
  version: "1.0.0"
  introspection:
    template_id: adapter
    tier: concrete
    parent: tier2_base_python
    variables:
      required:
        - name
      optional:
        - description
        - target_interface
        - methods
  agent_hints:
    phase: "green"
    purpose: "Generate adapter classes for external integrations"
-#}

{% block module_docstring %}
"""{{ name }} module.

{{ description | default('Adapter implementation.') }}

@layer: Backend (Adapters)
@target_interface: {{ target_interface | default('Unspecified') }}
"""
{% endblock %}

{% block imports_section %}
# Standard library
{{ p_logging.pattern_logging_imports() }}

# Third-party

# Project modules

{% endblock %}

{% block class_structure %}
{{ p_logging.pattern_logging_get_logger() }}

class {{ name }}:
    """{{ description | default(name + ' adapter.') }}"""
{% if methods %}
{% for method in methods %}

    def {{ method.name }}(self{% if method.params %}, {{ method.params }}{% endif %}){% if method.return_type %} -> {{ method.return_type }}{% endif %}:
        """{{ method.docstring | default(method.name + ' adapter method.') }}"""
        {{ method.body | default('pass') | indent(8) }}
{% endfor %}
{% else %}

    def adapt(self):
        """Adapt the external dependency to the local interface."""
        pass
{% endif %}
{% endblock %}
